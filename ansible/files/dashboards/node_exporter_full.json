{
  "title": "Node Exporter Full",
  "uid": "node_exporter_full",
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "showThresholdMarkers": true,
          "thresholdsStyle": {
            "mode": "line"
          }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 2,
      "title": "Memory Usage",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "showThresholdMarkers": true,
          "thresholdsStyle": {
            "mode": "line"
          }
        }
      },
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 }
    },
    {
      "id": 3,
      "title": "Disk Usage (/)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - ((node_filesystem_avail_bytes{mountpoint=\"/\"} * 100) / node_filesystem_size_bytes{mountpoint=\"/\"})",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "red", "value": 90 }
            ]
          },
          "showThresholdMarkers": true,
          "thresholdsStyle": {
            "mode": "line"
          }
        }
      },
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 4,
      "title": "Network Receive",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 }
    },
    {
      "id": 5,
      "title": "Network Transmit",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(node_network_transmit_bytes_total[5m])",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps"
        }
      },
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "title": "Load Average (1m)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "{{instance}}",
          "refId": "A",
          "datasource": "Prometheus",
          "interval": "15s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none"
        }
      },
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 }
    }
  ],
  "schemaVersion": 36,
  "version": 1
}